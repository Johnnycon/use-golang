type Room {
  id: ID!
  name: String!
}

type Message {
  id: ID!
  room: String!
  sender: String!
  text: String!
  timestamp: String!
  upvotes: Int!
}

type JobResult {
  messageId: ID!
  room: String!
  sender: String!
  result: Int!
  timestamp: String!
}

type CalorieQuery {
  id: ID!
  mealText: String!
  model: String!
  reasoningEffort: String
  calories: Int
  responseTimeMs: Int
  totalTokens: Int
  status: String!
  errorMessage: String
  createdAt: String!
}

type Query {
  """List all chat rooms."""
  rooms: [Room!]!

  """Fetch messages for a specific room."""
  messages(room: String!): [Message!]!

  """List all calorie queries, newest first."""
  calorieQueries: [CalorieQuery!]!
}

type Mutation {
  """Create a new chat room."""
  createRoom(name: String!): Room!

  """Send a message to a room."""
  sendMessage(room: String!, sender: String!, text: String!): Message!

  """Send a message and enqueue a surprise upvote job."""
  surpriseMe(room: String!, sender: String!, text: String!): Message!

  """Submit a meal for calorie estimation via LLM."""
  submitCalorieQuery(mealText: String!, modelName: String!, reasoningEffort: String): CalorieQuery!

  """Delete all calorie queries."""
  clearCalorieQueries: Boolean!

  """Delete a single calorie query by ID."""
  deleteCalorieQuery(id: ID!): Boolean!
}

type Subscription {
  """Real-time new messages in a room."""
  messageSent(room: String!): Message!

  """Notifies when an async job finishes processing a message (scoped to sender)."""
  jobCompleted(room: String!, sender: String!): JobResult!

  """Notifies all clients in a room when a surprise upvote is assigned."""
  surpriseUpvoteCompleted(room: String!): Message!

  """Notifies when a calorie estimation completes."""
  calorieQueryCompleted: CalorieQuery!
}
